<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns="http://schemas.microsoft.com/dotnet/maui/global"
			 x:DataType="StartViewModel"
			 x:Name="StartView"
             x:Class="PackMeUp.Views.StartPage"
             Title="Witamy">

    <ContentPage.Resources>
        <ResourceDictionary>
            <BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <StackLayout VerticalOptions="Center" HorizontalOptions="Center">
            <Label Text="Witaj w PackMeUp!" FontSize="24" />
            <Button Text="Zacznijmy pakowanie"
					Clicked="StartButton_Clicked"
					HorizontalOptions="Center" IsVisible="{Binding Session.HasLocalUser, Converter={StaticResource BoolToVisibilityConverter}}" />

            <Button Text="Start packing (TEST)" Command="{Binding StartPackingCommand}" />
            <!--<Button Text="Start packing (TEST)" Command="{Binding StartPackingCommand}" IsVisible="{Binding Session.HasLocalUser, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}" />-->
            <Button Text="Zaloguj przez Google" Command="{Binding LoginWithGoogleCommand}" IsVisible="{Binding Session.IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}" />
        </StackLayout>
    </Grid>

</ContentPage>