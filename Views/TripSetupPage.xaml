<?xml version="1.0" encoding="utf-8" ?>
<local:BasePage xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" 
             xmlns="http://schemas.microsoft.com/dotnet/maui/global"
             x:Class="PackMeUp.Views.TripSetupPage"
             xmlns:viewmodels="clr-namespace:PackMeUp.ViewModels"
             xmlns:local="clr-namespace:PackMeUp.Models.Pages"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             x:DataType="TripSetupViewModel"                
             Title="TripSetupPage">

    <VerticalStackLayout Padding="20" Spacing="25">

        <Grid RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="0.5*"/>
            </Grid.ColumnDefinitions>

            <StackLayout Grid.Row="0" Grid.ColumnSpan="2">
                <Label Text="Trip details:" FontSize="20" />
                <Entry Placeholder="Destination..." Text="{Binding Destination}"/>
            </StackLayout>
            
            <StackLayout Grid.Row="1" Grid.Column="0">
                <Label Text="Data rozpoczęcia" />
                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                    <Label Text="&#xe935;" FontFamily="MaterialIcons" FontSize="24" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnStartDateIconTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                    <DatePicker x:Name="StartDatePicker" Date="{Binding StartDate}" MinimumDate="{x:Static sys:DateTime.Today}" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </StackLayout>

            <StackLayout Grid.Row="1" Grid.Column="1">
                <Label Text="Data zakończenia" />
                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                    <Label Text="&#xe935;" FontFamily="MaterialIcons" FontSize="24" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnEndDateIconTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                    <DatePicker x:Name="EndDatePicker" Date="{Binding EndDate}" MinimumDate="{Binding StartDate}" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </StackLayout>
        </Grid>
        

        

        <Button
            Text="Utwórz listę"
            Command="{Binding CreateTripCommand}" />
    </VerticalStackLayout>
    
</local:BasePage>