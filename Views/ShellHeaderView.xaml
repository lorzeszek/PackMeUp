<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:PackMeUp.ViewModels"
             xmlns:converters="clr-namespace:PackMeUp.Converters"
             x:Class="PackMeUp.Views.ShellHeaderView"
             x:DataType="viewmodels:ShellHeaderViewModel"
             HorizontalOptions="FillAndExpand"
			 >

    <ContentView.Resources>
        <ResourceDictionary>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        </ResourceDictionary>
    </ContentView.Resources>

    <Grid Padding="10,5" BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}" HorizontalOptions="FillAndExpand">
        <HorizontalStackLayout HorizontalOptions="End" Spacing="10">
            
            <!-- Login Button (shown when NOT authenticated) -->
            <Button Text="Login"
                    Command="{Binding LoginWithGoogleCommand}"
                    IsVisible="{Binding Session.IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                    BackgroundColor="#4285F4"
                    TextColor="White"
                    CornerRadius="5"
                    Padding="15,8"
                    FontSize="14"/>

            <!-- User Info + Logout (shown when authenticated) -->
            <HorizontalStackLayout Spacing="10" 
                                   IsVisible="{Binding Session.IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}">
                <Label Text="{Binding Session.User.Email}"
                       VerticalOptions="Center"
                       FontSize="14"
                       TextColor="{AppThemeBinding Light=#333333, Dark=#CCCCCC}"/>
                
                <Button Text="Logout"
                        Command="{Binding LogoutCommand}"
                        BackgroundColor="#DC3545"
                        TextColor="White"
                        CornerRadius="5"
                        Padding="15,8"
                        FontSize="14"/>
            </HorizontalStackLayout>

        </HorizontalStackLayout>
    </Grid>

</ContentView>
