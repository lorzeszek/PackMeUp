<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="PackMeUp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:PackMeUp"
    FlyoutBehavior="Disabled"
    xmlns:views="clr-namespace:PackMeUp.Views"
    Title="PackMeUp">

    <Shell.TitleView>
        <views:ShellHeaderView />
    </Shell.TitleView>

        

    <TabBar>

        <Tab Title="Home" Icon="home.png">
            <ShellContent
                Route="Home"
                ContentTemplate="{DataTemplate views:StartPage}" />
        </Tab>

        <Tab Title="Trips" Icon="list.png">
            <ShellContent
                Route="TripList"
                ContentTemplate="{DataTemplate views:TripListPage}" />
        </Tab>

        <Tab Title="Weather" Icon="weather.png">
            <ShellContent
                Route="Weather"
                ContentTemplate="{DataTemplate views:WeatherPage}" />
        </Tab>

        <Tab Title="Docs" Icon="docs.png">
            <ShellContent
                Route="Docs"
                ContentTemplate="{DataTemplate views:DocsPage}" />
        </Tab>

    </TabBar>

</Shell>
